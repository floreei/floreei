{
  "name": "sistema-flores",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:all": "pnpm db:up && pnpm migration:run && pnpm dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && pnpm db:up && pnpm migration:run && pnpm db:seed",
    "migration:run": "pnpm --filter @sistema-flores/api migration:run",
    "migration:generate": "pnpm --filter @sistema-flores/api migration:generate",
    "db:seed": "pnpm --filter @sistema-flores/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "multer": "^2.2.0"
    }
  }
}