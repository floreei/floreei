# URL base da API (NestJS)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Firebase (config pública — não é segredo). Obrigatório: sem isso o app não
# inicializa o Firebase. Valores de DEV (***REMOVED***); troque em produção.
NEXT_PUBLIC_FIREBASE_API_KEY=***REMOVED***
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=***REMOVED***.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=***REMOVED***
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=***REMOVED***.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=***REMOVED***
NEXT_PUBLIC_FIREBASE_APP_ID=1:***REMOVED***:web:0c1fa8abb914c8d49cc5ce
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=***REMOVED***

# Vídeo de boas-vindas (opcional). Cole o link do YouTube/Vimeo/Loom ou um .mp4.
# Vazio → mostra a capa animada da marca. Ex.: https://www.loom.com/share/<id>
# NEXT_PUBLIC_WELCOME_VIDEO_URL=
