# API
PORT=3001
NODE_ENV=development

# Banco de dados (docker-compose: serviço postgres). Em produção, aponte para o
# Postgres gerenciado (ex.: Neon) e ligue o TLS com DATABASE_SSL=true.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5440
DATABASE_USER=flores
DATABASE_PASSWORD=flores
DATABASE_NAME=sistema_flores
# TLS obrigatório em Postgres gerenciado (Neon/Supabase exigem; RDS opcional).
# Verifica o certificado do servidor por padrão. Se o provedor usar um CA fora
# do bundle do Node (ex.: RDS sem o CA), relaxe com DATABASE_SSL_NO_VERIFY=true.
# DATABASE_SSL=true
# DATABASE_SSL_NO_VERIFY=true

# Firebase Auth — projectId do seu projeto real.
FIREBASE_PROJECT_ID=meuflorista-7dfd5
# apiKey pública (Identity Toolkit) — cadastro via REST sem service account e
# testes e2e. Não é segredo.
FIREBASE_API_KEY=AIzaSyDZ4ECH6gnuh3f70TryAmIrsQFrZiQuhtY

# Console do gestor — e-mails que viram OWNER no 1º login (csv). Bootstrap.
# PLATFORM_OWNER_EMAILS=voce@floreei.com

# CORS em produção: csv das origens do front. Vazio (dev) libera geral.
# CORS_ORIGINS=https://app.floreei.com.br,https://admin.floreei.com.br

# Service account (JSON): só p/ Admin SDK (criar/apagar usuário). Hoje roda sem.
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json

# Loja online — chave para cifrar segredos por-tenant (ex.: token do Mercado
# Pago) em repouso. Gere uma aleatória forte (>= 32 chars). Obrigatória em prod.
STORE_SECRETS_KEY=
# URL pública da API (usada no notification_url do webhook do Mercado Pago).
# Precisa ser acessível pela internet (em dev, use um túnel tipo ngrok/cloudflared).
STORE_PUBLIC_API_URL=http://localhost:3001/api
# Domínio base das lojas (subdomínio = slug): {slug}.floreei.com.br
STORE_BASE_DOMAIN=floreei.com.br

# Assinatura da plataforma (billing) — access token do Mercado Pago da conta da
# FLOREEI (a mensalidade do SaaS cai aqui; não confundir com o token por-loja).
# MP_PLATFORM_ACCESS_TOKEN=
# URL do app do cliente (back_url do checkout de assinatura → página /plano).
WEB_APP_URL=http://localhost:3000
