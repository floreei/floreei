# API
PORT=3001
NODE_ENV=development

# Banco de dados (docker-compose: serviço postgres)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5440
DATABASE_USER=flores
DATABASE_PASSWORD=flores
DATABASE_NAME=sistema_flores

# Firebase Auth — projectId do seu projeto real.
FIREBASE_PROJECT_ID=***REMOVED***
# Service account (JSON): obrigatória só para criar membros de equipe.
# Login/verificação de token funcionam apenas com o projectId.
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service-account.json
#
# Os testes (e2e) sobem o emulador automaticamente — não precisa configurar nada.
