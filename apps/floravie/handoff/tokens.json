{
  "$description": "Floravie Ateliê — design tokens. Fonte da verdade visual: reference/floravie-loja-completa.html",
  "color": {
    "ivory": "#FBF8F2",
    "paper": "#FFFFFF",
    "ink": "#26332C",
    "green": "#2F4A3C",
    "greenSoft": "#5F7A6B",
    "rose": "#C98A93",
    "roseDeep": "#A6606C",
    "roseMist": "#F4E4E4",
    "gold": "#B08D57",
    "line": "#E5DCD0",
    "footerBg": "#1F2A24",
    "footerText": "#C9CFC8",
    "footerLogo": "#F3EFE6",
    "whatsapp": "#25D366",
    "error": "#B03030",
    "overlay": "rgba(38,51,44,0.5)"
  },
  "font": {
    "display": {
      "family": "\"Cormorant Garamond\", Georgia, serif",
      "weights": [400, 500, 600],
      "italic": true,
      "googleFonts": "Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500"
    },
    "body": {
      "family": "\"Jost\", system-ui, sans-serif",
      "weights": [300, 400, 500, 600],
      "googleFonts": "Jost:wght@300;400;500;600"
    }
  },
  "typescale": {
    "h1Hero": "clamp(2.4rem, 5vw, 3.9rem)",
    "h2Section": "clamp(1.7rem, 3vw, 2.4rem)",
    "productCard": "1.22rem",
    "productModal": "2rem",
    "eyebrow": { "size": "0.72rem", "letterSpacing": "0.28em", "transform": "uppercase", "weight": 500, "color": "gold" },
    "nav": { "size": "0.78rem", "letterSpacing": "0.18em", "transform": "uppercase" },
    "button": { "size": "0.76rem", "letterSpacing": "0.18em", "transform": "uppercase", "weight": 500 },
    "bodyLineHeight": 1.6,
    "bodyWeight": 300
  },
  "radius": { "base": "14px", "input": "10px", "pill": "999px", "sheet": "19.6px", "aboutArt": "28px" },
  "shadow": {
    "base": "0 10px 30px rgba(47,74,60,0.10)",
    "hero": "0 24px 60px rgba(47,74,60,0.22)"
  },
  "layout": {
    "containerMax": "1200px",
    "containerPad": "24px",
    "breakpoints": { "nav": "920px", "stack": "820px", "modal": "760px", "rail": "720px", "form": "640px", "footer": "560px" }
  },
  "motion": {
    "fast": "0.2s",
    "card": "0.25s",
    "drawer": "0.3s",
    "imageZoom": "0.5s",
    "cardHover": { "translateY": "-5px", "imageScale": 1.05 },
    "petalDrift": { "duration": "9s", "translateY": "-22px", "rotate": "18deg", "delays": ["0s", "2.5s", "5s"] },
    "reducedMotion": true
  },
  "business": {
    "currency": "BRL",
    "shippingFee": 14.9,
    "freeShippingThreshold": 150.0,
    "pixDiscount": 0.05,
    "installments": 3,
    "qtyMin": 1,
    "qtyMax": 9,
    "orderNumberPrefix": "FLV-",
    "cities": ["Recife", "Olinda", "Jaboatão dos Guararapes", "Paulista", "Camaragibe", "São Lourenço da Mata", "Cabo de Santo Agostinho", "Igarassu", "Abreu e Lima", "Moreno"],
    "deliveryPeriods": { "manha": "8h–12h", "tarde": "13h–18h" },
    "sameDayCutoff": "16:00"
  }
}
